package day06;

public class 주사위게임 {

	public static void main(String[] args) {
		/* 주사위를 던져서 총 30칸을 이동하면 완주
		 * 주사위 수 : 1부터 6까지 랜덤 수 출력
		 * ex)
		 * 주사위 3 => 3칸 이동 => "27칸 남았습니다" 출력
		 * 주사위 6 => 6칸 이동 => "??칸 남았습니다" 출력
		 * ...
		 * 도착~~!! 총 이동 횟수: ?번 완주 
		 * */
		int num = 30;
		for(int i=1;i<=num;i++);{		
		int a = (int)(Math.random()*6)+1;
		int cnt = 0;
		int sum = 0;
		System.out.println("주사위: "+a);
		System.out.println(cnt+"칸 이동하였습니다.");
		cnt += a;
		sum += a;
		sum++;
		if(cnt==30) {
			System.out.println("도착~!!");
		} else {
			System.out.println(num-cnt+"칸 남았습니다.");
			
			
		
			
	
			
		}
		

	}

}
}
